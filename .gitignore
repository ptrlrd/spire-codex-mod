bin/
obj/
.godot/
.idea/
.vs/
*.user
*.suo
*.DotSettings.user
local.props

# Packaging output — keep the .gdignore so Godot never packs this dir
/dist/*
!/dist/.gdignore

# Local machine config (your Godot path / optional StS2 override).
# Copy Directory.Build.props.example -> Directory.Build.props and set your paths.
Directory.Build.props

# Steam Workshop staging — built mod files are copied here by tools/workshop-pack.sh
/workshop/content/*
!/workshop/content/.gitkeep

# ModUploader run log
mod-uploader.log

# Godot re-imports the Workshop thumbnail; the .import sidecar isn't game content
/workshop/*.import
